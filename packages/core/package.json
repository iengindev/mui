{
  "name": "@mui/core",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/mui.umd.js",
  "module": "./dist/mui.es.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "build": "npm run type-check && npm run build:only",
    "build:only": "vite build --",
    "type-check": "vue-tsc --build",
    "prepack": "npm run build"
  },
  "exports": {
    "./style.css": "./dist/core.css",
    ".": {
      "import": "./dist/mui.es.js",
      "types": "./dist/index.d.ts"
    }
  },
  "peerDependencies": {
    "vue": "^3.5.22"
  },
  "devDependencies": {
    "@tsconfig/node22": "^22.0.2",
    "@types/node": "^22.18.11",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vitejs/plugin-vue-jsx": "^5.1.1",
    "@vue/tsconfig": "^0.8.1",
    "typescript": "~5.9.0",
    "vite": "^7.1.11",
    "vite-plugin-dts": "^4.5.4",
    "vue-tsc": "^3.1.1"
  }
}
